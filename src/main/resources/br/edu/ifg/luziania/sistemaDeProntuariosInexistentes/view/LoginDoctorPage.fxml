<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--'dl' nos id's é Doctor Login-->

<AnchorPane fx:id="dlBackgroundBox"
            prefHeight="400.0"
            prefWidth="600.0"
            style="-fx-background-color: #18392B;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifg.luziania.sistemaDeProntuariosInexistentes.controller.LoginDoctorController">
   <AnchorPane fx:id="dLoginBox"
               layoutX="112.0"
               layoutY="85.0"
               prefHeight="231.0"
               prefWidth="376.0"
               style="-fx-background-color: #DCD0FF;
                      -fx-border-color: lightgreen;">
      <Label fx:id="dlWelcomeDoctorLabel"
             alignment="CENTER"
             contentDisplay="CENTER"
             layoutX="30.0"
             layoutY="28.0"
             text="Welcome Doctor!"
             textAlignment="CENTER"
             textFill="#18392b"
             AnchorPane.leftAnchor="30.0"
             AnchorPane.topAnchor="25.0">
         <font>
            <Font name="Fira Code Light" size="35.0"/>
         </font>
      </Label>
      <TextField fx:id="dlEmailCRMTextField"
                 layoutX="52.0"
                 layoutY="43.0"
                 prefHeight="26.0"
                 prefWidth="286.0"
                 promptText="Email or CRM"
                 AnchorPane.leftAnchor="45.0"
                 AnchorPane.rightAnchor="45.0"
                 AnchorPane.topAnchor="85.0">
         <font>
            <Font name="Noto Mono" size="13.0"/>
         </font>
      </TextField>
      <PasswordField fx:id="dlPasswordField"
                     layoutX="52.0"
                     layoutY="90.0"
                     prefHeight="26.0"
                     prefWidth="286.0"
                     promptText="Password"
                     AnchorPane.leftAnchor="45.0"
                     AnchorPane.rightAnchor="45.0"
                     AnchorPane.topAnchor="125.0">
         <font>
            <Font name="Noto Mono" size="13.0"/>
         </font>
      </PasswordField>
      <Hyperlink fx:id="dlCreateAccountHyperLink"
                 onAction="#handleCreateAccount"
                 layoutX="45.0"
                 layoutY="148.0"
                 prefHeight="33.0"
                 prefWidth="119.0"
                 text="Create account"
                 AnchorPane.bottomAnchor="30.0"
                 AnchorPane.leftAnchor="41.0">
         <font>
            <Font name="Noto Mono" size="13.0"/>
         </font>
      </Hyperlink>
      <Button fx:id="dlEnterButton"
              onAction="#handleLogin"
              alignment="CENTER"
              contentDisplay="CENTER"
              layoutX="270.0"
              layoutY="176.0"
              mnemonicParsing="false"
              prefHeight="30.0"
              prefWidth="83.0"
              style="-fx-border-width: 2;
                     -fx-border-radius: 10;
                     -fx-border-style: solid;
                     -fx-border-color: lightgreen;
                     -fx-background-color: #18392B;
                     -fx-background-radius: 10;
                     -fx-background-insets: 1"
              text="Enter"
              textAlignment="CENTER"
              textFill="LIGHTGREEN"
              AnchorPane.bottomAnchor="30.0"
              AnchorPane.rightAnchor="47.0">
         <font>
            <Font name="Noto Mono" size="13.0"/>
         </font>
      </Button>
   </AnchorPane>
   <Button fx:id="dlBackButton"
           onAction="#handleBackButton"
           layoutX="436.0"
           layoutY="373.0"
           mnemonicParsing="false"
           style="-fx-border-width:2;
                       -fx-border-radius: 10;
                       -fx-border-style: solid;
                       -fx-border-color: #7200A3;
                       -fx-background-color: #90ee90;
                       -fx-background-radius: 10;
                       -fx-background-insets: 1"
           text="Voltar"
           textAlignment="CENTER"
           textFill="#18392b"
           textOverrun="CENTER_ELLIPSIS"
           AnchorPane.rightAnchor="10.0"
           AnchorPane.topAnchor="10.0">
      <font>
         <Font name="Noto Mono" size="6.0" />
      </font>
   </Button>
</AnchorPane>
