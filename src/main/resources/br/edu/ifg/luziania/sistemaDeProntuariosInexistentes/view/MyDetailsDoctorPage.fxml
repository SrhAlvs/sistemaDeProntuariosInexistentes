<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--'dmd' nos id's é Doctor My Details-->

<AnchorPane prefHeight="400.0"
            prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifg.luziania.sistemaDeProntuariosInexistentes.controller.DoctorPagesController">
   <children>
      <AnchorPane fx:id="dmdPrincipalBox"
                  layoutX="120.0"
                  prefHeight="400.0"
                  prefWidth="480.0"
                  style="-fx-background-color: #18392B;"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
         <children>
            <Label fx:id="dmdMyDetailsLabel"
                   layoutX="35.0"
                   layoutY="11.0"
                   prefHeight="39.0"
                   prefWidth="182.0"
                   text="Meus dados"
                   textFill="#dcd0ff"
                   AnchorPane.leftAnchor="15.0"
                   AnchorPane.topAnchor="12.0">
               <font>
                  <Font name="Noto Mono" size="30.0" />
               </font>
            </Label>
            <Label fx:id="dmdFullNameLabel"
                   layoutX="54.0"
                   layoutY="100.0"
                   text="Nome completo:"
                   textFill="#dcd0ff"
                   AnchorPane.rightAnchor="320.0"
                   AnchorPane.topAnchor="100.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="dmdFullNameTextField"
                       editable="false"
                       layoutX="159.0"
                       layoutY="95.0"
                       prefHeight="26.0"
                       prefWidth="300.0"
                       text="fullname"
                       style="-fx-background-color: 0;
                              -fx-text-fill:#DCD0FF;"
                       AnchorPane.rightAnchor="25.0"
                       AnchorPane.topAnchor="95.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </TextField>
            <Label fx:id="dmdEmailLabel"
                   layoutX="54.0"
                   layoutY="153.0"
                   text="Email:"
                   textFill="#dcd0ff"
                   AnchorPane.rightAnchor="320.0"
                   AnchorPane.topAnchor="170.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="dmdEmailTextField"
                       editable="false"
                       layoutX="159.0"
                       layoutY="95.0"
                       prefHeight="26.0"
                       prefWidth="300.0"
                       text="email123@dominio.com"
                       style="-fx-background-color: 0;
                              -fx-text-fill:#DCD0FF;"
                       AnchorPane.rightAnchor="25.0"
                       AnchorPane.topAnchor="165.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </TextField>
            <Label fx:id="dmdCrmLabel"
                   layoutX="54.0"
                   layoutY="215.0"
                   text="CRM:"
                   textFill="#dcd0ff"
                   AnchorPane.rightAnchor="320.0"
                   AnchorPane.topAnchor="240.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="dmdCrmTextField"
                       editable="false"
                       layoutX="159.0"
                       layoutY="95.0"
                       prefHeight="26.0"
                       prefWidth="300.0"
                       text="123456-UF"
                       style="-fx-background-color: 0;
                              -fx-text-fill:#DCD0FF;"
                       AnchorPane.rightAnchor="25.0"
                       AnchorPane.topAnchor="235.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </TextField>
            <Label fx:id="dmdSpecialtyLabel" layoutX="54.0"
                   layoutY="290.0"
                   text="Especialidade:"
                   textFill="#dcd0ff"
                   AnchorPane.rightAnchor="320.0"
                   AnchorPane.topAnchor="310.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="dmdSpecialtyTextField"
                       editable="false"
                       layoutX="159.0"
                       layoutY="95.0"
                       prefHeight="26.0"
                       prefWidth="300.0"
                       text="specialty"
                       style="-fx-background-color: 0;
                              -fx-text-fill:#DCD0FF;"
                       AnchorPane.rightAnchor="25.0"
                       AnchorPane.topAnchor="305.0" >
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
            </TextField>
            <Button fx:id="dmdBackButton"
                    onAction="#handleBackHomeButton"
                    layoutX="436.0"
                    layoutY="373.0"
                    mnemonicParsing="false"
                    style="-fx-border-width:2;
                       -fx-border-radius: 10;
                       -fx-border-style: solid;
                       -fx-border-color: #7200A3;
                       -fx-background-color: #90ee90;
                       -fx-background-radius: 10;
                       -fx-background-insets: 1"
                    text="Voltar"
                    textAlignment="CENTER"
                    textFill="#18392b"
                    textOverrun="CENTER_ELLIPSIS"
                    AnchorPane.rightAnchor="10.0"
                    AnchorPane.topAnchor="10.0">
               <font>
                  <Font name="Noto Mono" size="6.0" />
               </font>
            </Button>
         </children></AnchorPane>
      <VBox fx:id="dmdMenuBox"
            prefHeight="400.0"
            prefWidth="122.0"
            style="-fx-background-color: #DCD0FF;"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.topAnchor="0.0">
         <children>
            <Label fx:id="dmdWelcomeLabel"
                   text="Bem vind@,"
                   textFill="#043c18">
               <font>
                  <Font name="Noto Mono" size="15.0" />
               </font>
               <VBox.margin>
                  <Insets left="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <Label fx:id="dmdDoctorNameLabel"
                   layoutX="15.0"
                   layoutY="15.0"
                   text="Fulano de Tal"
                   textFill="#0b8335">
               <font>
                  <Font name="Noto Mono" size="13.0" />
               </font>
               <VBox.margin>
                  <Insets left="5.0" top="2.0" />
               </VBox.margin>
            </Label>
            <Button fx:id="dmdHomeButton"
                    onAction="#handleBackHomeButton"
                    mnemonicParsing="false"
                    prefHeight="26.0"
                    prefWidth="124.0"
                    style="-fx-background-color: 0;
                           -fx-border-color: #BCA5FF;
                           -fx-border-style: solid;
                           -fx-border-width: 0.5;"
                    text="Início"
                    textFill="#043c18">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
               <font>
                  <Font name="Noto Mono" size="11.0" />
               </font>
            </Button>
            <Button fx:id="dmdMedicalRecordsButton"
                    onAction="#handleMedicalRecordsButton"
                    layoutX="10.0"
                    layoutY="62.0"
                    mnemonicParsing="false"
                    prefHeight="26.0"
                    prefWidth="124.0"
                    style="-fx-background-color: 0;
                           -fx-border-color: #BCA5FF;
                           -fx-border-style: solid;
                           -fx-border-width: 0.5;"
                    text="Prontuários"
                    textFill="#043c18">
               <font>
                  <Font name="Noto Mono" size="11.0" />
               </font>
            </Button>
         </children></VBox>
   </children>
</AnchorPane>
