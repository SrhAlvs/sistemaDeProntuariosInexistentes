   <children>
      <AnchorPane fx:id="dmrPrincipalBox" layoutX="120.0" prefHeight="400.0" prefWidth="480.0" style="-fx-background-color: #18392B;" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label fx:id="dmrMedicalRecordsLabel" layoutX="35.0" layoutY="11.0" prefHeight="39.0" prefWidth="182.0" text="Meus dados" textFill="#dcd0ff" AnchorPane.leftAnchor="15.0" AnchorPane.topAnchor="12.0">
               <font>
                  <Font name="Noto Mono" size="30.0" />
               </font>
            </Label>
            <Label layoutX="54.0" layoutY="100.0" text="Nome completo:" textFill="#dcd0ff" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="100.0" />
