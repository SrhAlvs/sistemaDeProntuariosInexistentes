      <VBox fx:id="dmrMenuBox" prefHeight="400.0" prefWidth="122.0" style="-fx-background-color: #DCD0FF;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
