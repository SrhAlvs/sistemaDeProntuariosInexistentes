            <Button fx:id="dmrAgendaButton" mnemonicParsing="false" prefHeight="26.0" prefWidth="124.0" style="-fx-background-color: 0;                            -fx-border-color: #BCA5FF;                            -fx-border-style: solid;                            -fx-border-width: 0.5;" text="Agenda" textFill="#043c18">
