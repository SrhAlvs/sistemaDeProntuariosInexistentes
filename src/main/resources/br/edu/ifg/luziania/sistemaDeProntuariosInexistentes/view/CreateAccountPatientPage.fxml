<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--'pca' nos id's é Patient Create Account-->

<StackPane fx:id="pcaBackgroundBox"
            prefHeight="400.0"
            prefWidth="600.0"
            style="-fx-background-color: lightgreen;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifg.luziania.sistemaDeProntuariosInexistentes.controller.PatientPagesController">
    <children>
        <VBox alignment="CENTER"
              spacing="20.0"
              fillWidth="false">
            <Label fx:id="pcaCreateYourAccountLabel"
                   alignment="CENTER"
                   text="Create your account"
                   textFill="#7200A3">
                <font>
                    <Font name="Noto mono" size="30.0" />
                </font>
            </Label>

            <AnchorPane fx:id="pCreateAccountBox"
                        prefHeight="231.0"
                        prefWidth="376.0"
                        style="-fx-border-width:2;
                               -fx-border-style: solid;
                               -fx-background-color: #7200A3;
                               -fx-border-color: #18392B;
                               -fx-background-insets: 1">
                <children>
                    <TextField fx:id="pcaFullNameTextField"
                               layoutX="46.0"
                               layoutY="27.0"
                               prefHeight="26.0"
                               prefWidth="286.0"
                               promptText="Full name"
                               AnchorPane.leftAnchor="46.0"
                               AnchorPane.rightAnchor="46.0"
                               AnchorPane.topAnchor="30.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </TextField>
                    <TextField fx:id="pcaCPFTextField"
                               layoutX="45.0"
                               layoutY="69.0"
                               prefHeight="26.0"
                               prefWidth="286.0"
                               promptText="CPF"
                               AnchorPane.leftAnchor="46.0"
                               AnchorPane.rightAnchor="46.0"
                               AnchorPane.topAnchor="60.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </TextField>
                    <TextField fx:id="pcaEmailTextField"
                               layoutX="57.0"
                               layoutY="71.0"
                               prefHeight="26.0"
                               prefWidth="286.0"
                               promptText="Email"
                               AnchorPane.leftAnchor="46.0"
                               AnchorPane.rightAnchor="46.0"
                               AnchorPane.topAnchor="90.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </TextField>
                    <PasswordField fx:id="pcaPasswordField"
                                   layoutX="52.0"
                                   layoutY="90.0"
                                   prefHeight="26.0"
                                   prefWidth="286.0"
                                   promptText="Password"
                                   AnchorPane.leftAnchor="46.0"
                                   AnchorPane.rightAnchor="46.0"
                                   AnchorPane.topAnchor="120.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </PasswordField>
                    <Hyperlink fx:id="pcaLoginHyperLink"
                               onAction="#handleBackToLoginHyperLink"
                               layoutX="43.0"
                               layoutY="167.0"
                               prefHeight="33.0"
                               prefWidth="48.0"
                               text="Login"
                               AnchorPane.bottomAnchor="33.0"
                               AnchorPane.leftAnchor="43.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </Hyperlink>
                    <Button fx:id="pcaCreateButton"
                            onAction="#handleCreateAccount"
                            alignment="CENTER"
                            contentDisplay="CENTER"
                            layoutX="270.0"
                            layoutY="176.0"
                            mnemonicParsing="false"
                            prefHeight="30.0"
                            prefWidth="83.0"
                            style="-fx-border-width: 2;
                                   -fx-border-radius: 10;
                                   -fx-border-style: solid;
                                   -fx-border-color: #18392B;
                                   -fx-background-color: lightgreen;
                                   -fx-background-radius: 10;
                                   -fx-background-insets: 1"
                            text="Create"
                            textAlignment="CENTER"
                            textFill="#18392B"
                            AnchorPane.bottomAnchor="30.0"
                            AnchorPane.rightAnchor="47.0">
                        <font>
                            <Font name="Noto Mono" size="13.0" />
                        </font>
                    </Button>
                </children>
            </AnchorPane>
        </VBox>
    </children>
</StackPane>
